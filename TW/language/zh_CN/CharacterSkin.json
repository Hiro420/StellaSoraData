{
  "CharacterSkin.10301.1": "琥珀-基础形象",
  "CharacterSkin.10302.1": "琥珀-觉醒形象",
  "CharacterSkin.10303.1": "玩心无邪",
  "CharacterSkin.10303.2": "锦绣织就流火，金饰点缀祥云。不怒自威、顾盼神飞。\u000b嘎呜——",
  "CharacterSkin.10304.1": "邀你静心，悠然一夏",
  "CharacterSkin.10304.2": "顺着炙热的海风，捉住那狂欢的隙间，悠悠然望向你的视线。",
  "CharacterSkin.10701.1": "缇莉娅-基础形象",
  "CharacterSkin.10702.1": "缇莉娅-觉醒形象",
  "CharacterSkin.10703.1": "此即吾之正义！",
  "CharacterSkin.10703.2": "系紧腰带，利落变身，斗志如烈阳般炽热！\u000b披上正义的战衣，以骑士之姿守护每一条街道——\u000b此即吾之正义！",
  "CharacterSkin.10801.1": "卡西米拉-基础形象",
  "CharacterSkin.10802.1": "卡西米拉-觉醒形象",
  "CharacterSkin.11001.1": "翡冷翠-基础形象",
  "CharacterSkin.11002.1": "翡冷翠-觉醒形象",
  "CharacterSkin.11101.1": "鸢尾-基础形象",
  "CharacterSkin.11102.1": "鸢尾-觉醒形象",
  "CharacterSkin.11103.1": "1/365的你",
  "CharacterSkin.11103.2": "冬日清冷阳光下的你，捧着热饮呼出白气的你，自诩平凡普通的你，却构成了这个日子全部的意义。",
  "CharacterSkin.11201.1": "尘沙-基础形象",
  "CharacterSkin.11202.1": "尘沙-觉醒形象",
  "CharacterSkin.11203.1": "日晒的余温",
  "CharacterSkin.11203.2": "来到大海，来到沙滩，当然得换上泳衣。\u000b怀抱热情的太阳，享受海浪的轻拍——与夏天的亲密接触，得务必注意防晒！",
  "CharacterSkin.11301.1": "师渺-基础形象",
  "CharacterSkin.11302.1": "师渺-觉醒形象",
  "CharacterSkin.11303.1": "辣就试试看吧！",
  "CharacterSkin.11303.2": "苍梧城内严禁辣椒成精！\u000b为、为了守护苍梧的和平，坚、坚持爱与正义的魔法少女，师渺命令你！快点变回原来的样子！",
  "CharacterSkin.11401.1": "猫眼-基础形象",
  "CharacterSkin.11402.1": "猫眼-觉醒形象",
  "CharacterSkin.11501.1": "火垂-基础形象",
  "CharacterSkin.11502.1": "火垂-觉醒形象",
  "CharacterSkin.11601.1": "岭川-基础形象",
  "CharacterSkin.11602.1": "岭川-觉醒形象",
  "CharacterSkin.11603.1": "郁蓊恒温室中憩",
  "CharacterSkin.11603.2": "我能想到最幸福的时刻，就是在午后的温暖中小憩。醒来时阳光晒过窗脚，而花朵仍在等你。",
  "CharacterSkin.11701.1": "璟麟-基础形象",
  "CharacterSkin.11702.1": "璟麟-觉醒形象",
  "CharacterSkin.11801.1": "科洛妮丝-基础形象",
  "CharacterSkin.11802.1": "科洛妮丝-觉醒形象",
  "CharacterSkin.11901.1": "花原-基础形象",
  "CharacterSkin.11902.1": "花原-觉醒形象",
  "CharacterSkin.11903.1": "异国风起时",
  "CharacterSkin.11903.2": "风摇云影间，曦光舞沙尘。与君共度时，唯有花窥见。",
  "CharacterSkin.12001.1": "卡娜丝-基础形象",
  "CharacterSkin.12002.1": "卡娜丝-觉醒形象",
  "CharacterSkin.12301.1": "杏子-基础形象",
  "CharacterSkin.12302.1": "杏子-觉醒形象",
  "CharacterSkin.12303.1": "漫游奇境的森林公主",
  "CharacterSkin.12303.2": "从古老的树洞跌入奇境，误入时间迷宫的小小公主啊，不必急于寻找出口，因为最棒的风景就藏在那些看似荒诞的梦里。",
  "CharacterSkin.12501.1": "苍兰-基础形象",
  "CharacterSkin.12502.1": "苍兰-觉醒形象",
  "CharacterSkin.12503.1": "落雪的赠礼",
  "CharacterSkin.12503.2": "她所期盼的雪愿节，是一炉温暖的火焰，一杯香甜的果酿，亲密好友的笑语，以及一份来自你的、独一无二的礼物。",
  "CharacterSkin.12601.1": "紫槿-基础形象",
  "CharacterSkin.12602.1": "紫槿-觉醒形象",
  "CharacterSkin.12701.1": "特丽莎-基础形象",
  "CharacterSkin.12702.1": "特丽莎-觉醒形象",
  "CharacterSkin.12703.1": "新人勇者前来报到",
  "CharacterSkin.12703.2": "拿起村里最好的宝剑，踏上勇者特丽莎的传奇冒险！欸~金光闪闪的宝箱？让我打开看看——呜哇——这是什么东西？！",
  "CharacterSkin.13001.1": "多娜-基础形象",
  "CharacterSkin.13002.1": "多娜-觉醒形象",
  "CharacterSkin.13201.1": "密涅瓦-基础形象",
  "CharacterSkin.13202.1": "密涅瓦-觉醒形象",
  "CharacterSkin.13203.1": "微醺白日梦",
  "CharacterSkin.13203.2": "手臂传来课桌板的清凉，后背感知洒落阳光的温暖。\u000b书本的芬芳令人陶醉——这是一场微醺的白日梦。",
  "CharacterSkin.13204.1": "粼粼镜影☆漆黑心伤",
  "CharacterSkin.13204.2": "对着镜子练习第一百零一次的冷酷表情，却在转头瞬间看到了你。于是所有伪装都崩溃，只剩下羞意。",
  "CharacterSkin.13301.1": "夏花-基础形象",
  "CharacterSkin.13302.1": "夏花-觉醒形象",
  "CharacterSkin.13303.1": "清露微滴的初夏",
  "CharacterSkin.13303.2": "一缕气息，初夏的花朵悄然绽放。一种触感，就像与你一同握住风车的那只手。",
  "CharacterSkin.13401.1": "冬香-基础形象",
  "CharacterSkin.13402.1": "冬香-觉醒形象",
  "CharacterSkin.13403.1": "平安度过试用期！",
  "CharacterSkin.13403.2": "按时打卡不迟到，材料认真准备好。勤勤恳恳，战战兢兢。哎呦喂——扑通，怎么还是搞砸了？",
  "CharacterSkin.13501.1": "雾语-基础形象",
  "CharacterSkin.13502.1": "雾语-觉醒形象",
  "CharacterSkin.13503.1": "可可甜心情与夜",
  "CharacterSkin.13503.2": "沉醉于可可的甜蜜，扫帚划过星空，将烦恼抛之脑后——这是只属于你们的浪漫冒险。",
  "CharacterSkin.14001.1": "斯帕克拉-基础形象",
  "CharacterSkin.14002.1": "斯帕克拉-觉醒形象",
  "CharacterSkin.14101.1": "赤霞-基础形象",
  "CharacterSkin.14102.1": "赤霞-觉醒形象",
  "CharacterSkin.14103.1": "镜中的红心皇后",
  "CharacterSkin.14103.2": "谁说镜中的世界就是虚幻？\u000b当她戴上皇后的冠冕，主角与反派位置对调，荒诞成了律法，舞台中心向她转移。\u000b——欢迎来到属于红皇后的奇境。",
  "CharacterSkin.14201.1": "珂赛特-基础形象",
  "CharacterSkin.14202.1": "珂赛特-觉醒形象",
  "CharacterSkin.14301.1": "风影-基础形象",
  "CharacterSkin.14302.1": "风影-觉醒形象",
  "CharacterSkin.14401.1": "千都世-基础形象",
  "CharacterSkin.14402.1": "千都世-觉醒形象",
  "CharacterSkin.14403.1": "牵牛花开，少女初醒",
  "CharacterSkin.14403.2": "养在水里的牵牛花——它的鲜亮和淡香，能保持多久呢？",
  "CharacterSkin.14501.1": "乙叶-基础形象",
  "CharacterSkin.14502.1": "乙叶-觉醒形象",
  "CharacterSkin.14701.1": "焦糖-基础形象",
  "CharacterSkin.14702.1": "焦糖-觉醒形象",
  "CharacterSkin.14703.1": "梦萌贝斯音",
  "CharacterSkin.14703.2": "滴滴嘟滴嘟，让一让！演出马上就要开始啦——\n请听——梦梦萌萌，软软咚咚，叮叮当当的贝斯梦境！",
  "CharacterSkin.14901.1": "格芮-基础形象",
  "CharacterSkin.14902.1": "格芮-觉醒形象",
  "CharacterSkin.14903.1": "相约融雪后",
  "CharacterSkin.14903.2": "咖啡的酸涩，蔷薇的芳香，想将一切新奇的体验都与你分享。融雪后，来一场约会吧？",
  "CharacterSkin.15001.1": "菈露-基础形象",
  "CharacterSkin.15002.1": "菈露-觉醒形象",
  "CharacterSkin.15501.1": "希娅-基础形象",
  "CharacterSkin.15502.1": "希娅-觉醒形象",
  "CharacterSkin.15601.1": "小禾-基础形象",
  "CharacterSkin.15602.1": "小禾-觉醒形象",
  "CharacterSkin.15603.1": "古灵精怪茶话会",
  "CharacterSkin.15603.2": "生活不过是如此吧：吃一块歌剧院，再沏一壶红茶。梦想正在膨胀，直至茶壶吐出蒸汽泡泡。",
  "CharacterSkin.15801.1": "菈露（圣夜）-基础形象",
  "CharacterSkin.15802.1": "菈露（圣夜）-觉醒形象",
  "CharacterSkin.15901.1": "科洛妮丝（新春）-基础形象",
  "CharacterSkin.15902.1": "科洛妮丝（新春）-觉醒形象"
}